# ---------------------------------------------------------------------------
# EduEnterprise environment. Copy to ".env" and adjust before deploying.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# --- PostgreSQL ---
POSTGRES_USER=edu
POSTGRES_PASSWORD=edu_secret
POSTGRES_DB=eduenterprise
DB_PORT=5432

# --- API (Node/Express) ---
API_PORT=4000
# IMPORTANT: generate a long random string for production, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_in_production_please
JWT_EXPIRES_IN=7d
# Origin the browser loads the app from (used for CORS).
CORS_ORIGIN=http://localhost:8080

# --- Web (React served by Nginx) ---
WEB_PORT=8080
# In Docker, Nginx proxies /api -> api service, so "/api" is correct.
# For a separately-hosted API, set the full URL e.g. https://your-api.onrender.com/api
VITE_API_BASE_URL=/api

# Public base URL used to build links inside emails (verification).
APP_BASE_URL=http://localhost:8088

# --- Email provider 1: Resend API (recommended, free tier) ---
# Get a key at https://resend.com/api-keys and REPLACE re_xxxxxxxxx below.
# Free tier notes: without a verified domain you must send FROM
# onboarding@resend.dev, and Resend only delivers to your own account email.
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM=GradeSure <onboarding@resend.dev>

# --- Email provider 2: SMTP fallback — OPTIONAL ---
# Used only when RESEND_API_KEY is blank. If both are blank, verification
# links are logged to the API console and returned in the register response
# (dev), so the hard email gate never locks you out.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GradeSure <no-reply@gradesure.local>

# --- Generative AI — OPTIONAL (Groq primary, Gemini fallback) ---
# Without keys the app uses a built-in rule-based generator (still fully works).
# Groq: https://console.groq.com/keys   Gemini: https://aistudio.google.com/apikey
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
